# ─────────────────────────────────────────
# GW 자동화 챗봇 환경 변수 예시
# 이 파일을 config/.env로 복사 후 실제 값 입력
# ─────────────────────────────────────────

# ── AI (필수) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── 그룹웨어 URL (필수) ──
GW_URL=https://gw.glowseoul.co.kr

# ── 관리자 계정 (필수) ──
ADMIN_GW_IDS=tgjeon

# ── JWT 인증 (필수 — 랜덤 문자열로 변경) ──
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET_KEY_32CHARS

# ── 암호화 키 (필수 — 랜덤 생성) ──
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# ── 텔레그램 봇 (선택) ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── GW TLS 검증 (사내 자체서명 인증서 사용 시) ──
# GW_SKIP_TLS_VERIFY=true

# ── GW 자동 동기화 스케줄러 ──
# cron 형식: 분 시 일 월 요일 (기본: 매일 오전 8시)
GW_SYNC_CRON=0 8 * * *
GW_SYNC_ENABLED=true

# ── CORS 허용 오리진 ──
ALLOWED_ORIGINS=http://localhost:51749
