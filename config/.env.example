# 그룹웨어 자동화 - 환경 변수 예시
# 이 파일을 복사하여 config/.env 로 저장한 뒤 실제 값을 채워주세요.
# .env 파일은 절대 공유/커밋하지 마세요.

# 그룹웨어 설정
GW_URL=https://gw.example.co.kr
GW_USER_ID=사용자아이디
GW_USER_PW=사용자비밀번호

# Notion 연동 (메일 요약 자동 저장)
# NOTION_API_KEY: https://www.notion.so/my-integrations 에서 발급
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx
# NOTION_PAGE_ID: 저장할 Notion 페이지 URL의 마지막 32자리 ID
# 예) https://www.notion.so/MyPage-abc123def456... → abc123def456...
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_WORKSPACE: 워크스페이스 이름 (선택)
NOTION_WORKSPACE=내_워크스페이스

# AI 모델 API 키
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# 보안 키 (임의의 강력한 문자열)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_SECRET=임의의_긴_랜덤_문자열

# 텔레그램 봇 토큰 (https://t.me/BotFather 에서 발급)
TELEGRAM_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
